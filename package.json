{
  "name": "ccinsight",
  "version": "0.1.0",
  "private": true,
  "description": "Interactive source code visualization & bilingual annotation tool",
  "workspaces": [
    "frontend",
    "backend",
    "gitnexus-shared"
  ],
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:frontend": "pnpm dev --workspace=frontend",
    "dev:backend": "pnpm dev:serve --workspace=backend",
    "dev:server": "pnpm dev:serve --workspace=backend",
    "build": "npm run build --workspace=gitnexus-shared && npm run build --workspace=frontend && npm run build --workspace=backend",
    "build:annotations": "node scripts/build-annotations.mjs",
    "setup": "node scripts/dev.mjs"
  },
  "keywords": [
    "code-analysis",
    "visualization",
    "annotations",
    "knowledge-graph"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  }
}
